# AI Configuration
GEMINI_API_KEY=your_gemini_api_key_from_aistudio.google.com

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=code_reviewer
DB_USER=your_db_username
DB_PASS=your_db_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Secret (minimum 32 characters, letters and numbers only)
JWT_SECRET=your_random_32_character_string_here

# Google OAuth (optional - leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost

# CORS Origins
CORS_ORIGINS=http://localhost,http://localhost:5173
