# ─────────────────────────────────────────────────────────────────────────────
# LLM Code Reviewer — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=code_reviewer
DB_USER=codereviewer
DB_PASS=your_secure_db_password_here

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 256 bits (32+ characters) for HS256
JWT_SECRET=your_super_long_jwt_secret_key_minimum_32_characters_long_here

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
# Free tier: 15 RPM, 1 million tokens/day, 1500 requests/day (as of 2024)
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# ── Google OAuth 2.0 ──────────────────────────────────────────────────────────
# Get credentials at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080/api
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
